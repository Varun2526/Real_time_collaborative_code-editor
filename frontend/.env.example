# Google OAuth (must match backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# GitHub OAuth (must match backend GITHUB_CLIENT_ID)
VITE_GITHUB_CLIENT_ID=your_github_client_id

# Backend API base URL
# Use your deployed HTTPS backend in production, for example:
# VITE_API_URL=https://api.example.com/api

# Socket.IO server URL
# Use the matching secure socket origin in production, for example:
# VITE_SOCKET_URL=https://api.example.com
